[32m+[m[32m        final note = noteProvider.notes.firstWhere((n) => n.id == noteId);[m
[32m+[m[32m        // Usar copyWithArchived en lugar de copyWith[m
[32m+[m[32m        final updatedNote = note.copyWithArchived(false);[m
[32m+[m[32m        await noteProvider.updateNote(updatedNote);[m
[32m+[m[32m      }[m
[32m+[m[41m      [m
