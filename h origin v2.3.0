[32m+[m
[32m+[m[32m  // Colores predefinidos para tipos comunes[m
[32m+[m[32m  static final Map<String, Color> defaultColors = {[m
[32m+[m[32m    'personal': Colors.blue,[m
[32m+[m[32m    'trabajo': Colors.orange,[m
[32m+[m[32m    'estudio': Colors.green,[m
[32m+[m[32m    'compras': Colors.purple,[m
[32m+[m[32m    'ideas': Colors.amber,[m
[32m+[m[32m    'proyecto': Colors.teal,[m
[32m+[m[32m    'urgente': Colors.red,[m
[32m+[m[32m    'salud': Colors.pink,[m
[32m+[m[32m    'viajes': Colors.indigo,[m
[32m+[m[32m    'hogar': Colors.brown,[m
[32m+[m[32m    'tecnología': Colors.cyan,[m
[32m+[m[32m    'finanzas': Colors.lightGreen,[m
[32m+[m[32m    'deportes': Colors.lime,[m
[32m+[m[32m    'música': Colors.deepPurple,[m
[32m+[m[32m    'lectura': Colors.blueGrey,[m
[32m+[m[32m  };[m
[32m+[m
[32m+[m[32m  // Obtener color basado en el nombre (para etiquetas nuevas)[m
[32m+[m[32m  static Color getColorForName(String name) {[m
[32m+[m[32m    // Buscar en colores predefinidos[m
[32m+[m[32m    final lowerName = name.toLowerCase();[m
[32m+[m[32m    if (defaultColors.containsKey(lowerName)) {[m
[32m+[m[32m      return defaultColors[lowerName]!;[m
[32m+[m[32m    }[m
[32m+[m[41m    [m
[32m+[m[32m    // Si no está predefinido, generar color basado en el hash del nombre[m
[32m+[m[32m    final hash = name.hashCode.abs();[m
[32m+[m[32m    final colorIndex = hash % Colors.primaries.length;[m
[32m+[m[32m    return Colors.primaries[colorIndex];[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  // Obtener icono sugerido basado en el nombre[m
[32m+[m[32m  static IconData? getIconForName(String name) {[m
[32m+[m[32m    switch (name.toLowerCase()) {[m
[32m+[m[32m      case 'personal':[m
[32m+[m[32m        return Icons.person;[m
[32m+[m[32m      case 'trabajo':[m
[32m+[m[32m        return Icons.work;[m
[32m+[m[32m      case 'estudio':[m
