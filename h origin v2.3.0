[32m+[m[32m      case 'música':[m
[32m+[m[32m        return Icons.music_note;[m
[32m+[m[32m      case 'lectura':[m
[32m+[m[32m        return Icons.book;[m
[32m+[m[32m      default:[m
[32m+[m[32m        return null;[m
[32m+[m[32m    }[m
[32m+[m[32m  }[m
