[32m+[m[32m        return Icons.shopping_cart;[m
[32m+[m[32m      case 'ideas':[m
[32m+[m[32m        return Icons.lightbulb;[m
[32m+[m[32m      case 'proyecto':[m
[32m+[m[32m        return Icons.assignment;[m
[32m+[m[32m      case 'urgente':[m
[32m+[m[32m        return Icons.warning;[m
[32m+[m[32m      case 'salud':[m
[32m+[m[32m        return Icons.favorite;[m
[32m+[m[32m      case 'viajes':[m
[32m+[m[32m        return Icons.flight;[m
[32m+[m[32m      case 'hogar':[m
[32m+[m[32m        return Icons.home;[m
[32m+[m[32m      case 'tecnología':[m
[32m+[m[32m        return Icons.computer;[m
[32m+[m[32m      case 'finanzas':[m
[32m+[m[32m        return Icons.attach_money;[m
[32m+[m[32m      case 'deportes':[m
