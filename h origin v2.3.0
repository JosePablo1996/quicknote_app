[32m+[m[32mclass _FavoritesScreenState extends State<FavoritesScreen> with TickerProviderStateMixin {[m
[32m+[m[32m  String _selectedCategory = 'Todas';[m
[32m+[m[32m  bool _isGridView = true;[m
[32m+[m[32m  bool _isSelectionMode = false;[m
[32m+[m[32m  Set<int> _selectedNoteIds = {};[m
[32m+[m[41m  [m
[32m+[m[32m  late AnimationController _animationController;[m
[32m+[m[32m  late Animation<double> _fadeAnimation;[m
[32m+[m
[32m+[m[32m  final List<String> _categories = ['Todas', 'Personal', 'Trabajo'];[m
[32m+[m
[32m+[m[32m  @override[m
[32m+[m[32m  void initState() {[m
[32m+[m[32m    super.initState();[m
[32m+[m[41m    [m
[32m+[m[32m    _animationController = AnimationController([m
[32m+[m[32m      vsync: this,[m
[32m+[m[32m      duration: const Duration(milliseconds: 400),[m
[32m+[m[32m    )..forward();[m
[32m+[m[41m    [m
[32m+[m[32m    _fadeAnimation = CurvedAnimation([m
[32m+[m[32m      parent: _animationController,[m
[32m+[m[32m      curve: Curves.easeOutCubic,[m
[32m+[m[32m    );[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  @override[m
[32m+[m[32m  void dispose() {[m
