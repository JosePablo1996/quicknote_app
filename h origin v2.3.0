[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  List<Note> _getFilteredNotes(List<Note> favorites) {[m
[32m+[m[32m    if (_selectedCategory == 'Todas') {[m
[32m+[m[32m      return favorites;[m
[32m+[m[32m    }[m
[32m+[m[41m    [m
[32m+[m[32m    return favorites.where((note) {[m
[32m+[m[32m      if (_selectedCategory == 'Personal') {[m
[32m+[m[32m        return note.tags.contains('personal');[m
[32m+[m[32m      } else if (_selectedCategory == 'Trabajo') {[m
[32m+[m[32m        return note.tags.contains('trabajo');[m
[32m+[m[32m      }[m
[32m+[m[32m      return true;[m
[32m+[m[32m    }).toList();[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  void _toggleSelectionMode() {[m
[32m+[m[32m    setState(() {[m
[32m+[m[32m      _isSelectionMode = !_isSelectionMode;[m
[32m+[m[32m      if (!_isSelectionMode) {[m
[32m+[m[32m        _selectedNoteIds.clear();[m
[32m+[m[32m      }[m
[32m+[m[32m    });[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  void _toggleNoteSelection(int noteId) {[m
[32m+[m[32m    setState(() {[m
[32m+[m[32m      if (_selectedNoteIds.contains(noteId)) {[m
[32m+[m[32m        _selectedNoteIds.remove(noteId);[m
[32m+[m[32m        if (_selectedNoteIds.isEmpty) {[m
[32m+[m[32m          _isSelectionMode = false;[m
[32m+[m[32m        }[m
[32m+[m[32m      } else {[m
[32m+[m[32m        _selectedNoteIds.add(noteId);[m
[32m+[m[32m        _isSelectionMode = true;[m
[32m+[m[32m      }[m
[32m+[m[32m    });[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  void _selectAllNotes(List<Note> notes) {[m
[32m+[m[32m    setState(() {[m
[32m+[m[32m      if (_selectedNoteIds.length == notes.length) {[m
[32m+[m[32m        _selectedNoteIds.clear();[m
[32m+[m[32m        _isSelectionMode = false;[m
[32m+[m[32m      } else {[m
[32m+[m[32m        _selectedNoteIds = notes.map((note) => note.id).toSet();[m
[32m+[m[32m        _isSelectionMode = true;[m
[32m+[m[32m      }[m
[32m+[m[32m    });[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  Future<void> _removeSelectedFromFavorites(List<Note> notes) async {[m
[32m+[m[32m    if (_selectedNoteIds.isEmpty) return;[m
[32m+[m[41m    [m
[32m+[m[32m    final bool? confirm = await showDialog<bool>([m
[32m+[m[32m      context: context,[m
[32m+[m[32m      builder: (context) => AlertDialog([m
[32m+[m[32m        title: const Text('Quitar de favoritos'),[m
[32m+[m[32m        content: Text('¿Quitar ${_selectedNoteIds.length} nota${_selectedNoteIds.length > 1 ? 's' : ''} de favoritos?'),[m
[32m+[m[32m        actions: [[m
[32m+[m[32m          TextButton([m
[32m+[m[32m            onPressed: () => Navigator.pop(context, false),[m
[32m+[m[32m            child: const Text('Cancelar'),[m
[32m+[m[32m          ),[m
[32m+[m[32m          ElevatedButton([m
[32m+[m[32m            onPressed: () => Navigator.pop(context, true),[m
[32m+[m[32m            style: ElevatedButton.styleFrom([m
[32m+[m[32m              backgroundColor: Colors.orange,[m
[32m+[m[32m            ),[m
[32m+[m[32m            child: const Text('Quitar'),[m
[32m+[m[32m          ),[m
[32m+[m[32m        ],[m
[32m+[m[32m      ),[m
[32m+[m[32m    );[m
[32m+[m
[32m+[m[32m    if (confirm == true) {[m
[32m+[m[32m      final noteProvider = Provider.of<NoteProvider>(context, listen: false);[m
[32m+[m[41m      [m
[32m+[m[32m      for (var noteId in _selectedNoteIds) {[m
[32m+[m[32m        final note = notes.firstWhere((n) => n.id == noteId);[m
[32m+[m[32m        final updatedNote = note.copyWithFavorite(false);[m
[32m+[m[32m        await noteProvider.updateNote(updatedNote);[m
[32m+[m[32m      }[m
[32m+[m[41m      [m
[32m+[m[32m      if (mounted) {[m
[32m+[m[32m        setState(() {[m
[32m+[m[32m          _selectedNoteIds.clear();[m
[32m+[m[32m          _isSelectionMode = false;[m
[32m+[m[32m        });[m
[32m+[m[41m        [m
[32m+[m[32m        SnackbarUtils.showSuccessSnackbar([m
[32m+[m[32m          context,[m
[32m+[m[32m          'Notas quitadas de favoritos',[m
[32m+[m[32m        );[m
[32m+[m[32m      }[m
[32m+[m[32m    }[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  String _getInitials(String title) {[m
[32m+[m[32m    if (title.isEmpty) return '?';[m
[32m+[m[32m    final words = title.split(' ');[m
[32m+[m[32m    if (words.length >= 2) {[m
[32m+[m[32m      return '${words[0][0]}${words[1][0]}'.toUpperCase();[m
[32m+[m[32m    }[m
[32m+[m[32m    return title[0].toUpperCase();[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  Color _getNoteColor(Note note) {[m
[32m+[m[32m    if (note.colorHex != null && note.colorHex!.isNotEmpty) {[m
[32m+[m[32m      try {[m
[32m+[m[32m        return Color(int.parse(note.colorHex!.replaceFirst('#', '0xff')));[m
[32m+[m[32m      } catch (e) {[m
[32m+[m[32m        final List<Color> colors = [[m
[32m+[m[32m          Colors.blue,[m
[32m+[m[32m          Colors.red,[m
[32m+[m[32m          Colors.green,[m
[32m+[m[32m          Colors.orange,[m
[32m+[m[32m          Colors.purple,[m
[32m+[m[32m          Colors.teal,[m
[32m+[m[32m          Colors.pink,[m
[32m+[m[32m          Colors.indigo,[m
[32m+[m[32m        ];[m
[32m+[m[32m        return colors[note.id % colors.length];[m
[32m+[m[32m      }[m
[32m+[m[32m    }[m
[32m+[m[41m    [m
[32m+[m[32m    final List<Color> colors = [[m
[32m+[m[32m      Colors.blue,[m
[32m+[m[32m      Colors.red,[m
[32m+[m[32m      Colors.green,[m
