<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- PERMISOS NECESARIOS -->
    
    <!-- Permiso de Internet (OBLIGATORIO para tu API) -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- PERMISOS PARA BIOMETRÍA Y SEGURIDAD -->
    <!-- Permiso para usar autenticación biométrica (huella digital) -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    
    <!-- Permiso para usar huella digital (versiones antiguas) -->
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    
    <!-- Permisos para funcionalidades FUTURAS (notas de voz) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    
    <!-- Para Android 13+ (permisos más específicos) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <application
        android:label="QuickNote"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:usesCleartextTraffic="true">
        <!-- 
            NOTAS:
            - allowBackup="false" desactiva el sistema de backup
            - usesCleartextTraffic="true" permite conexiones HTTP (útil para desarrollo)
        -->
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <!-- Especifica el tema a aplicar mientras se inicializa Flutter -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
                
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Configuración necesaria para Flutter -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- Consultas necesarias para funcionalidades de la app -->
    <queries>
        <!-- Para procesamiento de texto -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        <!-- Para reproducir audio (futuro) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="audio/*" />
        </intent>
        <!-- Para verificar disponibilidad de biometría -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
        </intent>
    </queries>
</manifest>